---
interface Props {
  title: string;
  company: string;
  period: string;
  location: string;
  description: string;
  tags: string[];
}

const { title, company, period, location, description, tags } = Astro.props;
---

<div class="relative pl-8 pb-8">
  <!-- Timeline dot -->
  <div class="absolute left-0 top-1.5 w-4 h-4 rounded-full bg-accent-cyan border-2 border-bg"></div>

  <!-- Card -->
  <div class="bg-surface border border-border rounded-lg p-6 hover:border-accent-cyan transition-colors duration-300">
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
      <div>
        <h3 class="text-lg font-semibold text-text">{title}</h3>
        <p class="text-accent-cyan font-medium">{company}</p>
      </div>
      <div class="text-sm text-text-secondary">
        <p>{period}</p>
        <p>{location}</p>
      </div>
    </div>

    <p class="text-text-secondary text-sm mb-4">{description}</p>

    <div class="flex flex-wrap gap-2">
      {tags.map(tag => (
        <span class="inline-block px-2 py-1 bg-cyan-500/10 border border-accent-cyan/30 text-cyan-400 text-xs rounded-md">
          {tag}
        </span>
      ))}
    </div>
  </div>
</div>
