---
interface Props {
  title: string;
  description: string;
  image: string;
  tags: string[];
}

const { title, description, image, tags } = Astro.props;
---

<div class="group relative bg-surface border border-border rounded-xl overflow-hidden hover:border-accent-cyan transition-all duration-300">
  <!-- Image -->
  <div class="relative h-64 sm:h-72 md:h-80 overflow-hidden bg-gradient-to-br from-cyan-500/20 via-violet-500/20 to-bg">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-bg via-transparent to-transparent"></div>

    <!-- TODO: reemplazar imagen
         - Dimensiones: 1200x675px (16:9)
         - Ruta: /public/projects/proyecto-nombre.webp
         - Formato: WebP para optimización
    -->
  </div>

  <!-- Content -->
  <div class="p-6 md:p-8">
    <h3 class="text-2xl font-bold text-text mb-3 group-hover:text-accent-cyan transition-colors">
      {title}
    </h3>

    <p class="text-text-secondary text-sm mb-5 leading-relaxed">
      {description}
    </p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2">
      {tags.map(tag => (
        <span class="inline-block px-3 py-1 bg-cyan-500/10 border border-accent-cyan/30 text-cyan-400 text-xs font-medium rounded-md">
          {tag}
        </span>
      ))}
    </div>
  </div>
</div>
