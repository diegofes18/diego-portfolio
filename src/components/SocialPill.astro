---
interface Props {
  href: string;
  label: string;
  icon: string;
}

const { href, label, icon } = Astro.props;
---

<a
  href={href}
  target={href.startsWith('mailto') ? '_self' : '_blank'}
  rel={href.startsWith('mailto') ? '' : 'noopener noreferrer'}
  class="inline-flex items-center gap-2 px-4 py-2 bg-surface border border-border rounded-lg hover:border-accent-cyan transition-colors duration-300"
>
  <span set:html={icon} class="w-5 h-5" />
  <span>{label}</span>
</a>
