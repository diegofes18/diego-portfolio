---
import Container from '../components/Container.astro';
import Avatar from '../components/Avatar.astro';
import Badge from '../components/Badge.astro';
import SocialPill from '../components/SocialPill.astro';

const linkedinIcon = `<svg fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/></svg>`;

const githubIcon = `<svg fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`;

const emailIcon = `<svg fill="currentColor" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>`;

const spainFlag = `<svg fill="none" viewBox="0 0 24 24"><rect width="24" height="24" fill="#C60B1E" rx="3"/><rect y="8" width="24" height="8" fill="#FFC400"/></svg>`;
---

<section class="relative min-h-screen flex items-center pt-32 md:pt-40 pb-20 md:pb-32 overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-20 right-10 w-96 h-96 rounded-full bg-cyan-500/5 blur-3xl"></div>
    <div class="absolute bottom-40 left-10 w-80 h-80 rounded-full bg-violet-500/5 blur-3xl"></div>
  </div>

  <Container class="relative z-10">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Left: Text content -->
      <div class="space-y-6">
        <!-- Greeting -->
        <div class="space-y-2">
          <p class="text-accent-cyan font-mono text-sm">Hey, I'm</p>
          <h1 class="text-5xl md:text-7xl font-bold tracking-tight">
            <span class="gradient-text">Diego</span>
          </h1>
        </div>

        <!-- Main title -->
        <div class="space-y-2">
          <h2 class="text-3xl md:text-4xl font-bold text-text">
            Data Engineer & Cloud Architect
          </h2>
          <div class="flex items-center gap-2">
            <span class="text-lg text-text">from Madrid</span>
            <span set:html={spainFlag} class="w-6 h-6"></span>
          </div>
        </div>

        <!-- Subtitle -->
        <p class="text-text-secondary text-lg leading-relaxed max-w-lg">
          I design and build scalable data pipelines on Azure and GCP. Specialized in cloud architectures, high-performance data processing, and distributed big data solutions.
        </p>

        <!-- Availability badge -->
        <div class="pt-2">
          <Badge variant="success">
            Available for work
          </Badge>
        </div>

        <!-- Contact info -->
        <div class="space-y-2 pt-4">
          <p class="text-text-secondary text-sm">
            <span class="font-medium">Email:</span> <a href="mailto:bermejodiego1@gmail.com" class="text-accent-cyan hover:underline">bermejodiego1@gmail.com</a>
          </p>
          <p class="text-text-secondary text-sm">
            <span class="font-medium">Phone:</span> <a href="tel:+34674082150" class="text-accent-cyan hover:underline">+34 674 082 150</a>
          </p>
        </div>

        <!-- Social buttons -->
        <div class="flex flex-wrap gap-3 pt-4">
          <SocialPill
            href="https://linkedin.com/in/diego-bermejo-cabañas-75b61a292"
            label="LinkedIn"
            icon={linkedinIcon}
          />
          <SocialPill
            href="https://github.com"
            label="GitHub"
            icon={githubIcon}
          />
          <SocialPill
            href="mailto:bermejodiego1@gmail.com"
            label="Email"
            icon={emailIcon}
          />
        </div>
      </div>

      <!-- Right: Avatar -->
      <div class="flex justify-center md:justify-end">
        <Avatar size="xl" class="ring-2 ring-accent-cyan/20" />
      </div>
    </div>
  </Container>
</section>
